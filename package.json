{
  "name": "@nodestrap/colors",
  "version": "2.0.1",
  "description": "A set of common color definition.",
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "@nodestrap/sass-class-template": "^2.0.2",
    "@nodestrap/sass-selector": "^2.0.1",
    "@nodestrap/sass-string": "^2.0.5"
  },
  "devDependencies": {
    "tilde-sass": "^1.0.0"
  },
  "scripts": {
    "test": "tilde-sass --file test/*.scss --outFile test/",
    "compile": "tilde-sass --file src/*.scss --outFile dist/ --outputStyle compressed"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nodestrap/colors.git"
  },
  "keywords": [
    "color",
    "colors",
    "web",
    "bootstrap",
    "theme"
  ],
  "author": "nodestrap, heymarco",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nodestrap/colors/issues"
  },
  "homepage": "https://github.com/nodestrap/colors#readme"
}
